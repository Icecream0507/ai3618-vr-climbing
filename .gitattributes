# Normalize line endings; let git auto-detect text vs binary.
* text=auto

# C# source
*.cs    text diff=csharp
*.shader text
*.cginc text
*.hlsl  text

# Unity YAML assets — merged with Unity's SmartMerge (UnityYAMLMerge).
# Each developer configures the merge driver locally once — see CONTRIBUTING.md §5.
*.unity      merge=unityyamlmerge eol=lf
*.prefab     merge=unityyamlmerge eol=lf
*.asset      merge=unityyamlmerge eol=lf
*.mat        merge=unityyamlmerge eol=lf
*.anim       merge=unityyamlmerge eol=lf
*.controller merge=unityyamlmerge eol=lf
*.physicMaterial merge=unityyamlmerge eol=lf
*.meta       merge=unityyamlmerge eol=lf

# Binary assets — no line-ending munging, no text diff.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.psd  binary
*.tga  binary
*.fbx  binary
*.blend binary
*.obj  binary
*.wav  binary
*.mp3  binary
*.ogg  binary
*.mp4  binary
*.unitypackage binary
*.dll  binary

